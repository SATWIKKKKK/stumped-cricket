# Neon
DATABASE_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cricket provider selection: free-dev | sportmonks
# Keep empty for auto mode: SportMonks when token exists, otherwise free-dev.
CRICKET_PROVIDER=
CRICKET_AUTO_SYNC=true

# Required when CRICKET_PROVIDER=sportmonks
SPORTMONKS_API_TOKEN=
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/cricket

# Required when CRICKET_PROVIDER=cricbuzz (or auto-detected when key exists)
CRICBUZZ_API_KEY=

# Optional but recommended for securing /api/admin/sync-cricket
CRICKET_SYNC_SECRET=
